    "NSPhotoLibraryUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We need access to your gallery in order to upload the document you've selected"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Profil fotoğrafı eklemek için galeriye erişim iznin gerekiyor"
